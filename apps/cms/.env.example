DATABASE_URL=postgres://<user>:<password>@127.0.0.1:5432/healdoor
PAYLOAD_SECRET=YOUR_SECRET_HERE
WEB_ORIGIN=http://localhost:3000
# Optional comma-separated list for extra production origins, e.g. https://healdoor.in,https://www.healdoor.in
WEB_ORIGINS=

# AWS S3 Storage Config
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=healdoor-prod-assets
